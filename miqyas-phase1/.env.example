# ═══════════════════════════════════════════════════════════════
#  متغيرات البيئة — منصة مِقياس
#  انسخ إلى .env على السيرفر: cp .env.example .env
#  ⚠️ لا ترفع .env إلى Git أبداً
# ═══════════════════════════════════════════════════════════════

# ── قاعدة البيانات (PostgreSQL + Prisma adapter-pg) ──
# الصيغة: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://miqyas:CHANGE_ME@localhost:5432/miqyas?schema=public"

# ── NextAuth ──
# NEXTAUTH_URL = عنوان التطبيق العام (HTTPS في الإنتاج)
NEXTAUTH_URL="https://SUBDOMAIN.example.org"
# توليد: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32"

# ── حساب المشرف (لأمر npm run seed فقط — أول تشغيل) ──
ADMIN_EMAIL="admin@zad.org.sa"
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

# ── البريد الإلكتروني (Microsoft 365 / Outlook) ──
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="miqyas@zad.org.sa"
SMTP_PASS="CHANGE_ME_APP_PASSWORD_OR_SMTP_SECRET"
SMTP_FROM="miqyas@zad.org.sa"

# ── التطبيق ──
APP_URL="https://SUBDOMAIN.example.org"

# ── Cron API (حماية /api/cron) ──
# توليد: openssl rand -hex 24
CRON_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_hex_24"

# ── ملاحظة: VPS_HOST / VPS_USER / VPS_SSH_KEY / VPS_APP_PATH ──
# تُضبط في GitHub Actions Secrets فقط — ليست في .env على السيرفر.
